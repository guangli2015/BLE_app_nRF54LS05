        <type>void</type>
        <definition>void nrfx_lpcomp_start</definition>
        <argsstring>(uint32_t lpcomp_evt_en_mask, uint32_t lpcomp_shorts_mask)</argsstring>
        <name>nrfx_lpcomp_start</name>
