        <name>NRFX_COMP_VOLTAGE_THRESHOLD_TO_INT</name>
        <param><defname>vol</defname></param>
        <param><defname>ref</defname></param>
        <initializer>    (uint8_t)(((vol) &gt; ((ref) / 64)) ? (<ref refid="group__nrfx__utils_1gace8c98e2beb5dae71ccd6da8a5c50f93" kindref="member">NRFX_ROUNDED_DIV</ref>((vol) * 64,(ref)) - 1) : 0)</initializer>
