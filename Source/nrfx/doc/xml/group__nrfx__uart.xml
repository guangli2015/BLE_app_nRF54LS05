      <memberdef kind="function" id="group__nrfx__uart_1gaf63d28dbfb92525905b48cda08c36fe0" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>void</type>
        <definition>void nrfx_uart_rx_enable</definition>
        <argsstring>(nrfx_uart_t *p_instance)</argsstring>
        <name>nrfx_uart_rx_enable</name>
        <param>
          <type><ref refid="structnrfx__uart__t" kindref="compound">nrfx_uart_t</ref> *</type>
          <declname>p_instance</declname>
        </param>
        <briefdescription>
<para>Function for enabling the receiver. </para>
        </briefdescription>
        <detaileddescription>
<para>UART has a 6-byte-long RX FIFO and it is used to store incoming data. If a user does not call the UART receive function before the FIFO is filled, an overrun error will appear. The receiver must be explicitly closed by the user <simplesect kind="see"><para><ref refid="group__nrfx__uart_1ga4a15a45d87d380d4f6142786cc387d5c" kindref="member">nrfx_uart_rx_disable</ref>.</para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">p_instance</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to the driver instance structure. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
        <location file="drivers/include/nrfx_uart.h" line="386" column="6" declfile="drivers/include/nrfx_uart.h" declline="386" declcolumn="6"/>
      </memberdef>
      <memberdef kind="function" id="group__nrfx__uart_1ga4a15a45d87d380d4f6142786cc387d5c" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
