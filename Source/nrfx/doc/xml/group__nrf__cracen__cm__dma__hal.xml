        <param><defname>mode_of_operation</defname></param>
        <param><defname>key_sel</defname></param>
        <param><defname>context_save</defname></param>
        <param><defname>context_load</defname></param>
        <param><defname>decrypt</defname></param>
        <initializer>    (  (((key_sel &gt;&gt; 2) &amp; 0x7) &lt;&lt; 28)     \
     | ((mode_of_operation &amp; 0x1FF) &lt;&lt; 8) \
     | ((key_sel &amp; 0x3) &lt;&lt; 6)             \
     | ((context_save ? 1 : 0) &lt;&lt; 5 )     \
     | ((context_load ? 1 : 0) &lt;&lt; 4 )     \
     | (decrypt ? 1 : 0)                  \
    )</initializer>
        <briefdescription>
<para>Generate the value to be written in the AES crypto engine configuration register given its parameters. </para>
