</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">_pin_sdout</parametername>
</parameternamelist>
<parameterdescription>
<para>SDOUT pin number. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
